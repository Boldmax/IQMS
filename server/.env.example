# ── DATABASE ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iqms_saas_db
DB_USER=postgres
DB_PASSWORD=change_me

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_at_least_32_random_characters
JWT_EXPIRES_IN=8h

# ── SERVER ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

 ── AI FEATURES (NCR root-cause assistant, welder doc extraction) ────────────
